# ---------------------------------------------------------------
# Copy this file to `.env` and fill in your real values.
# Never commit the real .env to Git.
# ---------------------------------------------------------------

# Google AI Studio key (only needed if LLM_PRIMARY_MODEL or LLM_FALLBACK_MODEL
# points to a gemini/* model). Get one free at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here

# Groq Cloud key (needed if either model is groq/*).
# Get one free at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# LLM model selection (LiteLLM identifiers).
# Examples:
#   groq/llama-3.1-8b-instant   — small, fast, very generous free quota
#   groq/llama-3.3-70b-versatile — bigger, slower, lower daily token cap
#   gemini/gemini-2.0-flash     — needs GEMINI_API_KEY + active free tier
# Leave LLM_FALLBACK_MODEL empty to disable the fallback chain entirely.
LLM_PRIMARY_MODEL=groq/llama-3.1-8b-instant
LLM_FALLBACK_MODEL=groq/meta-llama/llama-4-scout-17b-16e-instruct

# Server port (optional, defaults to 8000)
BACKEND_PORT=8000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
